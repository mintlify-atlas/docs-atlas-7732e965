  "keyFeatures": [
    "Multi-module research management system",
    "Project and grant call management (CSP)",
    "Ethics review and committee management (ETI)",
    "Intellectual property management (PII)",
    "Scientific production tracking (PRC)",
    "Integrated reporting system",
    "Keycloak-based authentication",
    "Microservices architecture",
    "Multi-language support (Spanish, English, Basque)",
    "Role-based access control"
  ],
  "publicApiSurface": [
    "CSP Service - Convocatorias (Calls), Solicitudes (Applications), Proyectos (Projects)",
    "ETI Service - Comités (Committees), Memorias (Reports), Evaluaciones (Evaluations)",
    "PII Service - Invenciones (Inventions), Solicitudes de Protección (Protection Requests)",
    "PRC Service - Producción Científica (Scientific Production)",
    "REP Service - Report Generation API",
    "COM Service - Communications and Email Templates",
    "CNF Service - Configuration Management",
    "USR Service - User Management",
    "TP Service - Scheduled Tasks",
    "REL Service - Module Relations",
    "EER Service - External Entity Relations"
  ]
